---
---
<div id="view-match" class="content-area hidden">
  <h2 class="section-title">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
    輸入比賽比分
  </h2>

  <div class="card">
    <form id="match-form" onsubmit="event.preventDefault();">
      <!-- Singles / Doubles Toggle -->
      <div class="form-group">
        <label class="form-label">比賽種類</label>
        <div class="form-toggle">
          <button type="button" id="btn-match-singles" class="form-toggle-btn active" data-mode="singles">單打</button>
          <button type="button" id="btn-match-doubles" class="form-toggle-btn" data-mode="doubles">雙打</button>
        </div>
      </div>

      <!-- Match Date & Type -->
      <div class="player-select-row">
        <div class="form-group" style="margin-bottom: 12px;">
          <label for="match-type" class="form-label">賽制類別</label>
          <select id="match-type" class="input-control">
            <option value="weekday">平日 (勝10/負3)</option>
            <option value="saturday">週六挑戰日 (勝15/負5)</option>
            <option value="season">季賽/年終賽 (勝30/負10)</option>
          </select>
        </div>
        <div class="form-group" style="margin-bottom: 12px;">
          <label for="match-datetime" class="form-label">比賽時間</label>
          <input type="datetime-local" id="match-datetime" class="input-control" required />
        </div>
      </div>

      <!-- TEAM A -->
      <div style="margin-top: 12px; border-bottom: 1px solid #E5E7EB; padding-bottom: 12px;">
        <span class="team-box-header team-box-a">A 隊 (Team A)</span>
        
        <!-- Player A1 -->
        <div class="player-select-row">
          <div class="form-group" style="margin-bottom: 8px;">
            <label class="form-label" style="font-size: 12px;">球員 A1</label>
            <select id="select-player-a1" class="input-control select-player" required>
              <option value="">選擇球員</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom: 8px;">
            <label class="form-label" style="font-size: 12px;">代表球隊</label>
            <select id="select-team-a1" class="input-control select-team" required>
              <option value="">選擇球隊</option>
            </select>
          </div>
        </div>

        <!-- Player A2 (Doubles only) -->
        <div id="row-player-a2" class="player-select-row hidden">
          <div class="form-group" style="margin-bottom: 8px;">
            <label class="form-label" style="font-size: 12px;">球員 A2</label>
            <select id="select-player-a2" class="input-control select-player">
              <option value="">選擇球員</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom: 8px;">
            <label class="form-label" style="font-size: 12px;">代表球隊</label>
            <select id="select-team-a2" class="input-control select-team">
              <option value="">選擇球隊</option>
            </select>
          </div>
        </div>
      </div>

      <!-- TEAM B -->
      <div style="margin-top: 16px; border-bottom: 1px solid #E5E7EB; padding-bottom: 12px;">
        <span class="team-box-header team-box-b">B 隊 (Team B)</span>
        
        <!-- Player B1 -->
        <div class="player-select-row">
          <div class="form-group" style="margin-bottom: 8px;">
            <label class="form-label" style="font-size: 12px;">球員 B1</label>
            <select id="select-player-b1" class="input-control select-player" required>
              <option value="">選擇球員</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom: 8px;">
            <label class="form-label" style="font-size: 12px;">代表球隊</label>
            <select id="select-team-b1" class="input-control select-team" required>
              <option value="">選擇球隊</option>
            </select>
          </div>
        </div>

        <!-- Player B2 (Doubles only) -->
        <div id="row-player-b2" class="player-select-row hidden">
          <div class="form-group" style="margin-bottom: 8px;">
            <label class="form-label" style="font-size: 12px;">球員 B2</label>
            <select id="select-player-b2" class="input-control select-player">
              <option value="">選擇球員</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom: 8px;">
            <label class="form-label" style="font-size: 12px;">代表球隊</label>
            <select id="select-team-b2" class="input-control select-team">
              <option value="">選擇球隊</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Scores Input -->
      <div style="margin-top: 16px; margin-bottom: 24px;">
        <label class="form-label">比賽比數</label>
        <div class="player-select-row">
          <div class="form-group" style="margin-bottom: 0;">
            <label for="score-a" class="form-label" style="font-size: 12px; color: var(--color-primary);">A 隊局數</label>
            <select id="score-a" class="input-control" required>
              <option value="6">6</option>
              <option value="0">0</option>
              <option value="1">1</option>
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4">4</option>
              <option value="5">5</option>
              <option value="7">7</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom: 0;">
            <label for="score-b" class="form-label" style="font-size: 12px; color: var(--color-accent-dark);">B 隊局數</label>
            <select id="score-b" class="input-control" required>
              <option value="4">4</option>
              <option value="0">0</option>
              <option value="1">1</option>
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="5">5</option>
              <option value="6">6</option>
              <option value="7">7</option>
            </select>
          </div>
        </div>
      </div>

      <button type="submit" id="btn-submit-match" class="btn btn-primary">
        <span>送出比分紀錄</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </button>
    </form>
  </div>
</div>
