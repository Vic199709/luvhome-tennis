---
---
<div id="view-add-member" class="content-area hidden">
  <h2 class="section-title">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
    新增聯盟會員
  </h2>

  <div class="card">
    <form id="add-member-form" onsubmit="event.preventDefault();" novalidate>
      <div id="add-member-form-error" class="form-error-banner hidden"></div>
      <!-- Player Name -->
      <div class="form-group">
        <label for="member-name" class="form-label">會員姓名</label>
        <input type="text" id="member-name" class="input-control" placeholder="請輸入姓名" required />
      </div>

      <!-- Player Phone -->
      <div class="form-group">
        <label for="member-phone" class="form-label">手機號碼</label>
        <input 
          type="tel" 
          id="member-phone" 
          class="input-control" 
          placeholder="請輸入手機號碼" 
          pattern="^09[0-9]{8}$" 
          inputmode="numeric" 
          required 
        />
        <div style="font-size: 11px; color: var(--color-text-muted); margin-top: 4px;">
          格式限制：09 開頭共 10 碼數字
        </div>
      </div>

      <!-- Gender -->
      <div class="form-group">
        <label class="form-label">性別</label>
        <div class="radio-group">
          <label class="radio-label">
            <input type="radio" name="member-gender" value="男" checked required />
            <span>男</span>
          </label>
          <label class="radio-label">
            <input type="radio" name="member-gender" value="女" required />
            <span>女</span>
          </label>
        </div>
      </div>

      <!-- Multi-select Representative Teams -->
      <div class="form-group">
        <label class="form-label">代表球隊 (可多選)</label>
        <div id="member-teams-checkboxes" class="multi-select-container">
          <!-- Dynamically populated checkboxes -->
          <div style="color: var(--color-text-muted); font-size: 14px; padding: 4px 0;">載入球隊中...</div>
        </div>
      </div>

      <button type="submit" id="btn-submit-member" class="btn btn-primary" style="margin-top: 10px;">
        <span>新增並提交審核</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
      </button>
    </form>
  </div>
</div>
