---
---
<div id="view-admin" class="content-area hidden">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
    <h2 class="section-title" style="margin-bottom: 0;">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      管理員審核主控台
    </h2>
    <button type="button" id="btn-admin-back" class="btn btn-secondary btn-sm" style="width: auto; height: 32px; padding: 0 12px;">
      返回個人頁
    </button>
  </div>

  <div class="card" style="padding: 16px;">
    <!-- Admin Tabs -->
    <div class="admin-tab-bar">
      <button type="button" id="btn-admin-tab-members" class="admin-tab-btn active">待驗證會員</button>
      <button type="button" id="btn-admin-tab-matches" class="admin-tab-btn">待驗證比賽</button>
    </div>

    <!-- Unverified Members List -->
    <div id="admin-members-section" class="admin-list">
      <div id="admin-members-placeholder" style="text-align: center; color: var(--color-text-muted); padding: 20px 0; font-size: 14px;">
        載入中...
      </div>
      <div id="admin-members-list" class="hidden">
        <!-- Dynamically loaded member cards -->
      </div>
    </div>

    <!-- Unverified Matches List -->
    <div id="admin-matches-section" class="admin-list hidden">
      <div id="admin-matches-placeholder" style="text-align: center; color: var(--color-text-muted); padding: 20px 0; font-size: 14px;">
        載入中...
      </div>
      <div id="admin-matches-list" class="hidden">
        <!-- Dynamically loaded match cards -->
      </div>
    </div>
  </div>
</div>
